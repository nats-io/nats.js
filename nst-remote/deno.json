{
  "name": "@nats-io/nst-remote",
  "version": "3.4.0",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "exclude": [
      "./.npmrc",
      "./build/",
      "./node_modules/",
      "./package-lock.json",
      "./package.json",
      "./tests/",
      "./tsconfig.json"
    ]
  },
  "lint": {
    "exclude": [
      "lib/",
      "build/"
    ]
  },
  "fmt": {
    "exclude": [
      "lib/",
      "build/"
    ]
  },
  "tasks": {
    "clean": "rm -rf ./lib ./build",
    "test": "deno test -A --parallel --reload tests/ --import-map=import_map.json"
  },
  "imports": {
    "@nats-io/nats-core": "jsr:@nats-io/nats-core@3.4.0",
    "@nats-io/nats-core/internal": "jsr:@nats-io/nats-core@3.4.0/internal",
    "@nats-io/nst": "jsr:@nats-io/nst@3.4.0",
    "@std/assert": "jsr:@std/assert@^1"
  }
}
